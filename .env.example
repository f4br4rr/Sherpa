# --- Local Ollama (OpenAI-compatible API) — no API key required on localhost:11434 ---
# 1) Install Ollama, then: `ollama pull qwen3` (or e.g. qwen3:8b — match SHERPA_LLM_MODEL)
# 2) `ollama serve` (often automatic)
SHERPA_LLM_PROVIDER=ollama
# SHERPA_LLM_BASE_URL=http://localhost:11434/v1
# SHERPA_LLM_MODEL=qwen3
# OLLAMA_MODEL=qwen3

# --- NVIDIA hosted (OpenAI-compatible) — used when SHERPA_NVIDIA_API_KEY is set and not using Ollama ---
# SHERPA_LLM_PROVIDER=openai
# SHERPA_NVIDIA_API_KEY=
# SHERPA_NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# SHERPA_NVIDIA_MODEL=nvidia/nemotron-3-super-120b-a12b

# --- Google Gemini ---
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# Optional corpus root for KO JSON (default: ./knowledge-objects/corpus)
# SHERPA_CORPUS_ROOT=
