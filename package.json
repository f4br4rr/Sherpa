{
  "name": "ghd-bot",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "build:lib": "tsc",
    "build:electron": "node scripts/build-electron.mjs",
    "build:renderer": "vite build",
    "build:desktop": "npm run build:renderer && npm run build:electron",
    "build": "npm run build:lib && npm run build:desktop",
    "dev": "npm run build:electron && concurrently -k \"vite\" \"node scripts/build-electron.mjs --watch\" \"wait-on http://127.0.0.1:5173 dist-electron/main.cjs dist-electron/preload.cjs && electron .\"",
    "start": "electron .",
    "validate:kos": "node scripts/validate-ko-corpus.mjs"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "concurrently": "^9.1.2",
    "electron": "^35.0.0",
    "esbuild": "^0.25.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.6",
    "typescript": "^5.8.2",
    "vite": "^6.2.2",
    "wait-on": "^8.0.2"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
